# Shared secret required on every POST /internal/notify request.
# Must match WS_INTERNAL_SECRET configured in the Netlify Functions environment.
WS_INTERNAL_SECRET=change-me-to-a-long-random-string

# Comma-separated list of browser origins allowed to open Socket.io connections.
ALLOWED_ORIGINS=https://acquiregame.netlify.app,http://localhost:8080

# Port the relay listens on (defaults to 3001).
PORT=3001
