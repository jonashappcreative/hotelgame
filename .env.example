# Frontend environment configuration
# Copy this file to .env.local and fill in your actual values.

# WebSocket relay the browser connects to for realtime room events.
# Local dev: the ws-server (see ws-server/). Production: your Hetzner subdomain.
VITE_WS_URL=http://localhost:3001
# VITE_WS_URL=wss://ws.acquiregame.jonashapp.com

# ---------------------------------------------------------------------------
# Backend secrets below are NOT used by the frontend build — they are set as
# Netlify environment variables (and on the Hetzner host). Listed here for
# reference. See docs/ARCHITECTURE.md.
#
#   DATABASE_URL          Neon Postgres connection string         (Netlify)
#   JWT_SECRET            Sign/verify auth tokens                  (Netlify)
#   WS_SERVER_URL         Internal URL of the Hetzner relay        (Netlify)
#   WS_INTERNAL_SECRET    Shared secret for /internal/notify       (Netlify + Hetzner)
#   ALLOWED_ORIGINS       Allowed browser origins (CORS/Socket.io) (Netlify + Hetzner)
# ---------------------------------------------------------------------------
